# OpenRouter API key — used server-side by api/proxy.js for turns 1–19.
# Get a free key at https://openrouter.ai → Keys → Create Key.
# Never committed; never exposed to the browser.
OPENROUTER_KEY=sk-or-v1-your-key-here

# Optional: extra allowed CORS origin for a custom domain in production.
# ALLOWED_ORIGIN=https://yourdomain.com
